CREATE TABLE modules (

    id SERIAL PRIMARY KEY,

    name VARCHAR(100) NOT NULL UNIQUE,

    route VARCHAR(150) NOT NULL,

    icon VARCHAR(100) NOT NULL,

    description TEXT

);

CREATE TABLE roles (

    id SERIAL PRIMARY KEY,

    name VARCHAR(50) NOT NULL UNIQUE,

    modules JSONB NOT NULL

);

CREATE TABLE users (

    id SERIAL PRIMARY KEY,

    first_name VARCHAR(100) NOT NULL,

    last_name VARCHAR(100) NOT NULL,

    email VARCHAR(255) NOT NULL UNIQUE,

    password_hash TEXT NOT NULL,

    role_id INTEGER NOT NULL,

    is_active BOOLEAN NOT NULL DEFAULT TRUE,

    created_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,

    updated_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,

    CONSTRAINT fk_users_role
        FOREIGN KEY(role_id)
        REFERENCES roles(id)

);

CREATE TABLE audit_logs (

    id SERIAL PRIMARY KEY,

    user_id INTEGER,

    username VARCHAR(150) NOT NULL,

    user_role VARCHAR(50) NOT NULL,


    action VARCHAR(100) NOT NULL,

    entity VARCHAR(100),

    entity_id INTEGER,


    description TEXT NOT NULL,


    old_data JSONB,

    new_data JSONB,


    ip_address VARCHAR(50),

    created_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,


    CONSTRAINT fk_audit_user
        FOREIGN KEY(user_id)
        REFERENCES users(id)
        ON DELETE SET NULL

);

CREATE TABLE forecast (

    id SERIAL PRIMARY KEY,


    -- Fecha del periodo que se está prediciendo
    forecast_date DATE NOT NULL,


    -- Categoría EONET
    -- FIRE, FLOOD, STORM, VOLCANO...
    category VARCHAR(100) NOT NULL,


    -- Región geográfica
    -- Asia, Europe, North America...
    region VARCHAR(100) NOT NULL,


    -- País específico
    country VARCHAR(100),


    -- Cantidad esperada de eventos
    expected_events INTEGER NOT NULL,


    -- Confianza del modelo 0-1
    confidence FLOAT NOT NULL,


    -- LOW / MEDIUM / HIGH / CRITICAL
    risk_level VARCHAR(20) NOT NULL,


    -- Intervalos de predicción
    lower_bound FLOAT,

    upper_bound FLOAT,


    -- Modelo utilizado
    model_version VARCHAR(50) NOT NULL,


    -- Información adicional del entrenamiento
    extra_data JSONB,


    -- Fecha cuando se generó el forecast
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,


    -- Forecast vigente
    active BOOLEAN NOT NULL DEFAULT TRUE

);


CREATE TABLE event_categories (

    id SERIAL PRIMARY KEY,


    -- Nombre limpio usado por nuestro sistema
    name VARCHAR(100) NOT NULL,


    -- Nombre original NASA
    external_name VARCHAR(150) NOT NULL,

    description TEXT,


    active BOOLEAN DEFAULT TRUE,


    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,


    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP

);

CREATE TABLE user_alerts (

    id SERIAL PRIMARY KEY,


    user_id INTEGER NOT NULL,


    name VARCHAR(150),


    latitude DOUBLE PRECISION NOT NULL,


    longitude DOUBLE PRECISION NOT NULL,


    country VARCHAR(100),


    state VARCHAR(100),


    radius_km INTEGER DEFAULT 100,


    min_risk_level VARCHAR(20) DEFAULT 'LOW',


    frequency VARCHAR(20) NOT NULL,


    preferred_day INTEGER,


    last_sent_at TIMESTAMP,


    next_send_at TIMESTAMP,


    enabled BOOLEAN DEFAULT TRUE,


    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,


    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,


    CONSTRAINT fk_alert_user
    FOREIGN KEY(user_id)
    REFERENCES users(id)

);



CREATE TABLE user_alert_categories (

    id SERIAL PRIMARY KEY,


    alert_id INTEGER NOT NULL,


    category_id INTEGER NOT NULL,


    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,


    CONSTRAINT fk_alert
    FOREIGN KEY(alert_id)
    REFERENCES user_alerts(id)
    ON DELETE CASCADE,


    CONSTRAINT fk_category
    FOREIGN KEY(category_id)
    REFERENCES event_categories(id)
    ON DELETE CASCADE,


    UNIQUE(alert_id,category_id)

);


CREATE TABLE alert_notifications (

    id SERIAL PRIMARY KEY,


    alert_id INTEGER NOT NULL,


    category_id INTEGER,


    message TEXT NOT NULL,


    risk_level VARCHAR(20),


    forecast_id INTEGER,


    sent_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,


    status VARCHAR(20) DEFAULT 'SENT',


    error_message TEXT,


    CONSTRAINT fk_notification_alert
    FOREIGN KEY(alert_id)
    REFERENCES user_alerts(id)
    ON DELETE CASCADE,


    CONSTRAINT fk_notification_category
    FOREIGN KEY(category_id)
    REFERENCES event_categories(id)

);
-- ============================
-- ÍNDICES
-- ============================


CREATE INDEX idx_forecast_date
ON forecast(forecast_date);



CREATE INDEX idx_forecast_category
ON forecast(category);



CREATE INDEX idx_forecast_region
ON forecast(region);



CREATE INDEX idx_forecast_country
ON forecast(country);



CREATE INDEX idx_forecast_risk_level
ON forecast(risk_level);



CREATE INDEX idx_forecast_created_at
ON forecast(created_at);



CREATE INDEX idx_forecast_active
ON forecast(active);

